-- Check whether a target model is valid to pull.
local function patchToolForNoSpread(tool)
    if not tool or not tool:IsA("Tool") then
        return
    end

    local state = getPatchedToolState(tool)
    if not state then
        return
    end

    state.active.NoSpread = true

    for _, descendant in ipairs(tool:GetDescendants()) do
        if descendant:IsA("NumberValue") or descendant:IsA("IntValue") then
            local lowerName = string.lower(descendant.Name)
            if lowerName:find("spread") or lowerName:find("cone") or lowerName:find("inaccuracy") or lowerName:find("recoil") or lowerName:find("bloom") then
                applyToolPatchValue(state, descendant, "Value", 0)
            end
        elseif descendant:IsA("ModuleScript") then
            patchModuleNumericKeys(state, descendant, {
                { pattern = "spread", value = 0 },
                { pattern = "cone", value = 0 },
                { pattern = "inaccuracy", value = 0 },
                { pattern = "recoil", value = 0 },
                { pattern = "bloom", value = 0 },
                { pattern = "hipspread", value = 0 },
                { pattern = "hip_spread", value = 0 },
                { pattern = "aimspread", value = 0 },
                { pattern = "aim_spread", value = 0 }
            })
        end
    end
end

local function isValidTarget(char)
    if not char or char == LocalPlayer.Character then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not root or not hum or hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then 
        return false 
    end
    
    local plr = Players:GetPlayerFromCharacter(char)
    if plr and isSameTeam(plr) then return false end
    
    if char:FindFirstChildOfClass("ForceField") then return false end
    if hum.MaxHealth >= 999999 then return false end
    
    local entityState = char:GetAttribute("EntityState")
    if entityState and entityState ~= 1 then return false end
    
    return true
end

local function getPullTargetRoot(char)
    if not isValidTarget(char) then
        return nil
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        return nil
    end

    return getRootAssembly(root) or root
end

local function getTargetPartByName(char, preferredPartName)
    if not isValidTarget(char) then
        return nil
    end

    local preferredPart = char:FindFirstChild(preferredPartName)
    if preferredPart and preferredPart:IsA("BasePart") then
        return preferredPart
    end

    local fallbackParts = { "Head", "HumanoidRootPart", "UpperTorso", "Torso" }
    for _, partName in ipairs(fallbackParts) do
        local part = char:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return part
        end
    end

    return nil
end

local function getAimbotTargetPart(char)
    return getTargetPartByName(char, aimbotAimPart)
end


local function isAimbotTargetVisible(targetPart)
    if not Camera or not targetPart then
        return false
    end

    local origin = Camera.CFrame.Position
    local direction = targetPart.Position - origin
    if direction.Magnitude <= 0 then
        return false
    end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

    local filter = {}
    if LocalPlayer.Character then
        table.insert(filter, LocalPlayer.Character)
    end
    table.insert(filter, Camera)

    raycastParams.FilterDescendantsInstances = filter

    local result = Workspace:Raycast(origin, direction, raycastParams)
    return result == nil or result.Instance:IsDescendantOf(targetPart.Parent)
end

local function getBestTarget(getTargetPart, maxFov, visibleOnly)
    if not Camera then
        return nil
    end

    local mouseLocation = UserInputService:GetMouseLocation()
    local mousePosition = Vector2.new(mouseLocation.X, mouseLocation.Y)
    local bestCharacter = nil
    local bestScreenDistance = maxFov

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and isValidTarget(player.Character) then
            local targetPart = getTargetPart(player.Character)
            if targetPart then
                local screenPoint, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen and screenPoint.Z > 0 then
                    local screenPosition = Vector2.new(screenPoint.X, screenPoint.Y)
                    local screenDistance = (screenPosition - mousePosition).Magnitude

                    if screenDistance <= bestScreenDistance and (not visibleOnly or isAimbotTargetVisible(targetPart)) then
                        bestScreenDistance = screenDistance
                        bestCharacter = player.Character
                    end
                end
            end
        end
    end

    return bestCharacter
end

local function getBestAimbotTarget()
    return getBestTarget(getAimbotTargetPart, aimbotFov, aimbotVisibleOnly)
end


local function getPullTargetPosition(myRoot)
    return (myRoot.CFrame * CFrame.new(
        math.round(pullOffsetX / pullOffsetXStep) * pullOffsetXStep,
        math.round(pullOffsetY / pullOffsetYStep) * pullOffsetYStep,
        -pullDistance
    )).Position
end

local function getCharacterAimPoint(character)
    if not character then
        return nil
    end

    local head = character:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head.Position
    end

    local upperTorso = character:FindFirstChild("UpperTorso")
    if upperTorso and upperTorso:IsA("BasePart") then
        return upperTorso.Position + Vector3.new(0, upperTorso.Size.Y * 0.35, 0)
    end

    local torso = character:FindFirstChild("Torso")
    if torso and torso:IsA("BasePart") then
        return torso.Position + Vector3.new(0, torso.Size.Y * 0.35, 0)
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if root and root:IsA("BasePart") then
        return root.Position + Vector3.new(0, root.Size.Y * 0.5, 0)
    end

    return nil
end

local function getBestPullTargets(myRoot)
    local candidates = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and isValidTarget(player.Character) then
            local targetRoot = getPullTargetRoot(player.Character)
            local targetHumanoid = player.Character:FindFirstChildOfClass("Humanoid")
            local aimPoint = getCharacterAimPoint(player.Character)

            if targetRoot and targetHumanoid and targetHumanoid.Health > 0 and aimPoint then
                local distance = (myRoot.Position - aimPoint).Magnitude
                if distance <= pullRadius then
                    table.insert(candidates, {
                        character = player.Character,
                        distance = distance,
                        targetRoot = targetRoot
                    })
                end
            end
        end
    end

    table.sort(candidates, function(a, b)
        return a.distance < b.distance
    end)

    local selectedTargets = {}
    for i = 1, math.min(pullMaxTargets, #candidates) do
        selectedTargets[i] = candidates[i]
    end

    return selectedTargets
end


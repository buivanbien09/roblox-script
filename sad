        clickTeleportConnection:Disconnect()
        clickTeleportConnection = nil
    end

    if Toggles then
        if Toggles.SpeedToggle then Toggles.SpeedToggle:SetValue(false) end
        if Toggles.FlyToggle then Toggles.FlyToggle:SetValue(false) end
        if Toggles.NoclipToggle then Toggles.NoclipToggle:SetValue(false) end
        if Toggles.InfJump then Toggles.InfJump:SetValue(false) end

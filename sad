        return
    end

    local originalCFrame = myRoot.CFrame
    local originalPlatformStand = myHumanoid.PlatformStand
    local velocityBody = Instance.new("BodyVelocity")
    velocityBody.Name = "FlingForce"
    velocityBody.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    velocityBody.P = 125000
    velocityBody.Velocity = Vector3.zero
    velocityBody.Parent = myRoot

    myHumanoid.PlatformStand = true

    local success, err = pcall(function()
        local endTime = tick() + 0.75
        while tick() < endTime do
            if not targetCharacter.Parent or targetHumanoid.Health <= 0 then
                break
            end

            local currentTargetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
            if not currentTargetRoot then
                break
            end

            local spinAngle = tick() * 40
            local offset = CFrame.Angles(0, spinAngle, 0).LookVector * 3
            myRoot.CFrame = CFrame.new(currentTargetRoot.Position + offset, currentTargetRoot.Position)
            velocityBody.Velocity = (offset.Unit * flingVelocityForce) + Vector3.new(0, flingVelocityForce * 0.35, 0)
            RunService.Heartbeat:Wait()
        end
    end)

    velocityBody:Destroy()
    stopRootMotion(myRoot)
    myRoot.CFrame = originalCFrame
    myHumanoid.PlatformStand = originalPlatformStand
    myHumanoid:ChangeState(Enum.HumanoidStateType.GettingUp)

    if not success then
        notify("Fling failed: " .. tostring(err), 3)
    end
end


RunService.Heartbeat:Connect(function()
    Camera = Workspace.CurrentCamera or Camera

    local character = LocalPlayer.Character
    if character then
        applyCharacterFootState(character)
    end

    if shouldSuppressCharacterMotion() then
        return
    end

    local root = getRootPart()
    local humanoid = getHumanoid()
    local equippedTool = character and character:FindFirstChildOfClass("Tool")

    if spamChatEnabled then
        local now = tick()
        local message = trimString(spamChatMessage)
        if message ~= "" and now - lastSpamChatTime >= spamChatDelay then
            if sendChatMessage(message) then
                lastSpamChatTime = now
            end
        end
    end

    if autoPickupEnabled then
        autoPickupNearbyItems()
    end

    for tool, state in pairs(patchedToolStates) do
        state.active.NoSpread = false
        state.active.InstantReload = false
        state.active.RapidFire = false

        local shouldKeepPatched = tool == equippedTool and (
            noSpreadEnabled or instantReloadEnabled or rapidFireEnabled
        )

        if not shouldKeepPatched then
            restorePatchedTool(tool)
        end
    end

    if equippedTool then
        if noSpreadEnabled then
            patchToolForNoSpread(equippedTool)
        end

        if instantReloadEnabled then
            patchToolForInstantReload(equippedTool)
        end

        if rapidFireEnabled then
            patchToolForRapidFire(equippedTool)
        end
    end

    if humanoid then
        if speedEnabled then
            local method = Options.SpeedMethod and Options.SpeedMethod.Value or "WalkSpeed"
            local moving = humanoid.MoveDirection.Magnitude > 0

            if method == "WalkSpeed" then
                humanoid.WalkSpeed = walkSpeed
            elseif method == "CFrame" and moving and root then
                root.CFrame = root.CFrame + (humanoid.MoveDirection * (walkSpeed / 60))
            elseif method == "Velocity" and moving and root then
                local horizontalVelocity = humanoid.MoveDirection * walkSpeed
                root.AssemblyLinearVelocity = Vector3.new(horizontalVelocity.X, root.AssemblyLinearVelocity.Y, horizontalVelocity.Z)
            end
        else
            local defaultWalkSpeed = 16
            if humanoid.WalkSpeed ~= defaultWalkSpeed then
                humanoid.WalkSpeed = defaultWalkSpeed
            end
        end
    end
    
    if noclipEnabled then
        local char = getCharacter()
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end

            applyCharacterFootState(char)
        end
    elseif LocalPlayer.Character then
        restoreCharacterCollisionState(LocalPlayer.Character)
    end
    
    if antiWindEnabled and root then
        local assemblyRoot = getRootAssembly(root)
        if assemblyRoot then
            local velocity = assemblyRoot.AssemblyLinearVelocity
            assemblyRoot.AssemblyLinearVelocity = Vector3.new(velocity.X, math.clamp(velocity.Y, -2, 2), velocity.Z)
            assemblyRoot.AssemblyAngularVelocity = Vector3.zero
        end
    end
    
    if Toggles.AntiJumpscare and Toggles.AntiJumpscare.Value then
        pcall(function()
            for _, sound in pairs(Workspace:GetDescendants()) do
                if sound:IsA("Sound") and sound.Playing and (sound.Volume > 1.5 or sound.PlaybackSpeed > 1.5) then sound.Volume = 0 end
            end
        end)
    end
end)


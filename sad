-- Utility Functions
local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getRootAssembly(root)
    if not root then
        return nil
    end

    return root.AssemblyRootPart or root
end

local function getCharacterFeetParts(character)
    local feetParts = {}
    if not character then
        return feetParts
    end

    for _, partName in ipairs({ "LeftFoot", "RightFoot", "Left Leg", "Right Leg" }) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            table.insert(feetParts, part)
        end
    end

    return feetParts
end

local function rememberCharacterCollisionState(character)
    if not character then
        return
    end

    characterCollisionStates = {}

    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            characterCollisionStates[part] = {
                CanCollide = part.CanCollide,
                Massless = part.Massless
            }
        end
    end
end

local function applyCharacterFootState(character)
    if not noclipEnabled then
        return
    end

    for _, footPart in ipairs(getCharacterFeetParts(character)) do
        footPart.CanCollide = false
        footPart.Massless = true
    end
end

local function restoreCharacterCollisionState(character)
    if not character then
        return
    end

    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            local originalState = characterCollisionStates[part]
            if originalState then
                part.CanCollide = originalState.CanCollide
                part.Massless = originalState.Massless
            end
        end
    end

    characterCollisionStates = {}
end


local function serverHop()
    local cursor = ""
    local currentJobId = game.JobId
    local placeId = game.PlaceId

    local function buildUrl()
        local baseUrl = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor ~= "" then
            baseUrl = baseUrl .. "&cursor=" .. HttpService:UrlEncode(cursor)
        end
        return baseUrl
    end

    local ok, targetJobId = pcall(function()
        while true do
            local response = game:HttpGet(buildUrl())
            local decoded = HttpService:JSONDecode(response)

            if decoded and decoded.data then
                for _, server in ipairs(decoded.data) do
                    if server.id ~= currentJobId and server.playing < server.maxPlayers then
                        return server.id
                    end
                end
            end

            cursor = decoded and decoded.nextPageCursor or nil
            if not cursor or cursor == "" then
                break
            end
        end

        return nil
    end)

    if ok and targetJobId then
        joinJobId(targetJobId)
    elseif ok then
        notify("No available server found.", 3)
    else
        notify("Server hop failed.", 4)
    end
end

local function sendChatMessage(message)
    local text = trimString(message)
    if text == "" then
        return false
    end

    if textChatService and textChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local textChannels = textChatService:FindFirstChild("TextChannels")
        local generalChannel = textChannels and textChannels:FindFirstChild("RBXGeneral")
        if generalChannel and generalChannel.SendAsync then
            return pcall(function()
                generalChannel:SendAsync(text)
            end)
        end
    end

    local replicatedStorage = game:FindService("ReplicatedStorage")
    local defaultChatSystemEvents = replicatedStorage and replicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
    local sayMessageRequest = defaultChatSystemEvents and defaultChatSystemEvents:FindFirstChild("SayMessageRequest")
    if sayMessageRequest then
        return pcall(function()
            sayMessageRequest:FireServer(text, "All")
        end)
    end

    return false
end

local function getAvailableTeamCheckMode()
    local myChar = LocalPlayer.Character
    if not myChar then
        return nil
    end

    local hasRobloxTeam = false
    local hasFactionType = false
    local hasTeamAttribute = false
    local hasIntTeamValue = false
    local hasStringTeamValue = false
    local hasTeamColor = false

    local otherPlayers = Players:GetPlayers()
    for _, player in ipairs(otherPlayers) do
        if player ~= LocalPlayer and player.Character then
            if LocalPlayer.Team ~= nil and player.Team ~= nil then
                hasRobloxTeam = true
            end

            local myFaction = myChar:GetAttribute("FactionType")
            local theirFaction = player.Character:GetAttribute("FactionType")
            if myFaction ~= nil and theirFaction ~= nil then
                hasFactionType = true
            end

            local myTeamAttribute = myChar:GetAttribute("Team") or LocalPlayer:GetAttribute("Team")
            local theirTeamAttribute = player.Character:GetAttribute("Team") or player:GetAttribute("Team")
            if myTeamAttribute ~= nil and theirTeamAttribute ~= nil then
                hasTeamAttribute = true
            end

            local myTeamValue = myChar:FindFirstChild("Team") or LocalPlayer:FindFirstChild("Team")
            local theirTeamValue = player.Character:FindFirstChild("Team") or player:FindFirstChild("Team")
            if myTeamValue and theirTeamValue then
                if myTeamValue:IsA("IntValue") and theirTeamValue:IsA("IntValue") then
                    hasIntTeamValue = true
                end
                if myTeamValue:IsA("StringValue") and theirTeamValue:IsA("StringValue") then
                    hasStringTeamValue = true
                end
            end

            if LocalPlayer.TeamColor ~= nil and player.TeamColor ~= nil then
                hasTeamColor = true
            end
        end
    end

    if hasRobloxTeam then
        return "Roblox Teams"
    end
    if hasFactionType then
        return "FactionType Attribute"
    end
    if hasTeamAttribute then
        return "Team Attribute"
    end
    if hasIntTeamValue then
        return "IntValue (Team)"
    end
    if hasStringTeamValue then
        return "StringValue (Team)"
    end
    if hasTeamColor then
        return "TeamColor"
    end

    return nil
end

-- Team Check helper (Moved up for global access)
local function isSameTeam(player)
    if not ESPSettings.TeamCheck then return false end

    local myChar = LocalPlayer.Character
    local theirChar = player.Character
    if not myChar or not theirChar then return false end

    local mode = Options.TeamCheckMode and Options.TeamCheckMode.Value or "Auto Detect"
    if mode == "Auto Detect" then
        detectedTeamCheckMode = getAvailableTeamCheckMode()
        if detectedTeamCheckMode ~= lastDetectedTeamCheckMode then
            lastDetectedTeamCheckMode = detectedTeamCheckMode
            if detectedTeamCheckMode then
                notify("Auto detected team check: " .. detectedTeamCheckMode, 3)
            end
        end
        mode = detectedTeamCheckMode or "Auto (Try All)"
    else
        detectedTeamCheckMode = nil
        lastDetectedTeamCheckMode = nil
    end

    local function checkRobloxTeam()
        if LocalPlayer.Team and player.Team then
            return LocalPlayer.Team == player.Team
        end
        return false
    end

    local function checkFactionType()
        local a = myChar:GetAttribute("FactionType")
        local b = theirChar:GetAttribute("FactionType")
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    local function checkTeamAttribute()
        local a = myChar:GetAttribute("Team") or LocalPlayer:GetAttribute("Team")
        local b = theirChar:GetAttribute("Team") or player:GetAttribute("Team")
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    local function checkIntValue()
        local function getInt(char, plr)
            local v = char:FindFirstChild("Team") or plr:FindFirstChild("Team")
            if v and v:IsA("IntValue") then return v.Value end
            return nil
        end
        local a = getInt(myChar, LocalPlayer)
        local b = getInt(theirChar, player)
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    local function checkStringValue()
        local function getStr(char, plr)
            local v = char:FindFirstChild("Team") or plr:FindFirstChild("Team")
            if v and v:IsA("StringValue") then return v.Value end
            return nil
        end
        local a = getStr(myChar, LocalPlayer)
        local b = getStr(theirChar, player)
        if a ~= nil and b ~= nil and a ~= "" then return a == b end
        return false
    end

    local function checkTeamColor()
        if LocalPlayer.TeamColor and player.TeamColor then
            return LocalPlayer.TeamColor == player.TeamColor
        end
        return false
    end

    if mode == "Roblox Teams" then return checkRobloxTeam()
    elseif mode == "FactionType Attribute" then return checkFactionType()
    elseif mode == "Team Attribute" then return checkTeamAttribute()
    elseif mode == "IntValue (Team)" then return checkIntValue()
    elseif mode == "StringValue (Team)" then return checkStringValue()
    elseif mode == "TeamColor" then return checkTeamColor()
    else
        return checkRobloxTeam() or checkFactionType() or checkTeamAttribute() or checkIntValue() or checkStringValue() or checkTeamColor()
    end
end

-- Fly System
local flyBV, flyBG = nil, nil

local function startFly()
    local root = getRootPart()
    if not root then return end
    local humanoid = getHumanoid()
    if humanoid then humanoid.PlatformStand = true end
    
    flyBV = Instance.new("BodyVelocity")
    flyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    flyBV.Velocity = Vector3.new(0, 0, 0)
    flyBV.Parent = root
    
    flyBG = Instance.new("BodyGyro")
    flyBG.P = 9e4
    flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    flyBG.CFrame = root.CFrame
    flyBG.Parent = root
end

local function stopFly()
    local humanoid = getHumanoid()
    if humanoid then humanoid.PlatformStand = false end
    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end
end


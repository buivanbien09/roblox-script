local function refreshTeleportPlayerList()
    teleportPlayerNames = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(teleportPlayerNames, player.Name)
        end
    end
    table.sort(teleportPlayerNames, function(a, b)
        return string.lower(a) < string.lower(b)
    end)

    if teleportDropdown then
        teleportDropdown:SetValues(teleportPlayerNames)
        if #teleportPlayerNames > 0 then
            local current = teleportDropdown.Value
            if not current or current == "" or not table.find(teleportPlayerNames, current) then
                teleportDropdown:SetValue(teleportPlayerNames[1])
            end
        else
            selectedTeleportPlayer = nil
        end
    end
end

local function refreshSavedPointDropdown()
    if not savedPointDropdown then
        return
    end

    local pointNames = getSavedTeleportPointNames()
    savedPointDropdown:SetValues(pointNames)

    if #pointNames > 0 then
        if not selectedSavedTeleportPoint or selectedSavedTeleportPoint == "" or not table.find(pointNames, selectedSavedTeleportPoint) then
            selectedSavedTeleportPoint = pointNames[1]
            savedPointDropdown:SetValue(selectedSavedTeleportPoint)
        end
    else
        selectedSavedTeleportPoint = nil
    end
end

local function saveCurrentTeleportPoint()
    local root = getRootPart()
    if not root then
        notify("Your character root part was not found.", 3)
        return
    end

    local pointName = "Point " .. tostring(#getSavedTeleportPointNames() + 1)
    local nextIndex = 1

    while State.savedTeleportPoints[pointName] do
        nextIndex = nextIndex + 1
        pointName = "Point " .. tostring(nextIndex)
    end

    State.savedTeleportPoints[pointName] = root.CFrame
    selectedSavedTeleportPoint = pointName
    refreshSavedPointDropdown()
    notify("Saved point: " .. pointName, 3)
end

local function teleportToSavedPoint()
    local root = getRootPart()
    local targetCFrame = selectedSavedTeleportPoint and State.savedTeleportPoints[selectedSavedTeleportPoint] or nil

    if not root then
        notify("Your character root part was not found.", 3)
        return
    end

    if not targetCFrame then
        notify("Please select a saved point.", 3)
        return
    end

    stopRootMotion(root)
    root.CFrame = targetCFrame
end

local function deleteSavedPoint()
    if not selectedSavedTeleportPoint or not State.savedTeleportPoints[selectedSavedTeleportPoint] then
        notify("Please select a saved point.", 3)
        return
    end

    State.savedTeleportPoints[selectedSavedTeleportPoint] = nil
    selectedSavedTeleportPoint = nil
    refreshSavedPointDropdown()
    notify("Saved point deleted.", 3)
end


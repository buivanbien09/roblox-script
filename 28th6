end

local function startFreezePositionLock()
    stopFreezePositionLock()

    State.freezePositionLockConnection = RunService.Stepped:Connect(function()
        if not State.freezeEnabled or not State.freezePos then
            return
        end

        local root = getRootPart()
        local humanoid = getHumanoid()
        local assemblyRoot = getRootAssembly(root)

        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        end

        if assemblyRoot then
            assemblyRoot.CFrame = State.freezePos
            stopRootMotion(assemblyRoot)
        end
    end)
end

local function setPromptInstant(prompt, enabled)
    if not prompt or not prompt:IsA("ProximityPrompt") then
        return
    end

    if enabled then
        if State.promptHoldDurations[prompt] == nil then
            State.promptHoldDurations[prompt] = prompt.HoldDuration
        end
        prompt.HoldDuration = 0
    else
        local originalDuration = State.promptHoldDurations[prompt]
        if originalDuration ~= nil then
            prompt.HoldDuration = originalDuration
            State.promptHoldDurations[prompt] = nil
        end
    end
end

